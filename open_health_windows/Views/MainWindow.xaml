<?xml version="1.0" encoding="utf-8"?>

<Window
    x:Class="open_health_windows.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:open_health_windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Open Health">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Open Health" Grid.Row="0">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/app_logo.png"/>
            </TitleBar.IconSource>
        </TitleBar>

        <InfoBar x:Name="AppInfoBar" IsOpen="False" Grid.Row="1" Margin="20,5,20,5" />

        <Grid Grid.Row="2" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="10">
                <Button Content="Load new image" Click="LoadImageButton_Click" HorizontalAlignment="Stretch"/>
                <Button Content="Load folder" Click="LoadFolderButton_Click" HorizontalAlignment="Stretch"/>

                <DropDownButton HorizontalAlignment="Stretch">
                    <TextBlock x:Name="SelectedHardwareText" Text="Hardware: CPU"/>
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedLeft">
                            <MenuFlyoutItem Text="CPU" Tag="CPU" Click="HardwareMenu_Click"/>
                            <MenuFlyoutItem Text="iGPU" Tag="iGPU" Click="HardwareMenu_Click"/>
                            <MenuFlyoutItem Text="NPU" Tag="NPU" Click="HardwareMenu_Click"/>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>

                <StackPanel Spacing="5" Margin="0,10,0,10">
                    <TextBlock Text="Model precision:" FontWeight="Medium" FontSize="12"/>
                    <RadioButton x:Name="FloatModelRadio" Content="FP32 (Original)" IsChecked="True" GroupName="ModelType"/>
                    <RadioButton x:Name="QuantizedModelRadio" Content="INT8 (Quantized)" GroupName="ModelType"/>
                </StackPanel>

                <Button Content="Analyze" Click="AnalyzeButton_Click" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}"/>
                <Button x:Name="StopButton" Content="Stop analysis" Click="StopButton_Click" IsEnabled="False" HorizontalAlignment="Stretch"/>
                <Button Content="Save result" Click="SaveResultButton_Click" HorizontalAlignment="Stretch"/>

                <TextBlock x:Name="ProgressText" 
                           Text="Ready" 
                           Margin="0,20,0,0" 
                           FontSize="14" 
                           FontWeight="SemiBold" 
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Image x:Name="LoadedImage" 
                   Grid.Column="1" 
                   MaxWidth="400" 
                   MaxHeight="400" 
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="3" Margin="20,0,20,10">
            <ProgressBar x:Name="AnalysisProgressBar" 
             Visibility="Collapsed" 
             HorizontalAlignment="Left" 
             Width="200" 
             VerticalAlignment="Center"
             Foreground="DodgerBlue"/>

            <TextBlock Text="DISCLAIMER: This application is for test purposes only. It is NOT a medical device and does NOT provide real diagnosis. With any skin issues, see a doctor!" 
           FontSize="10" 
           Foreground="Gray" 
           HorizontalAlignment="Center" 
           TextWrapping="Wrap" 
           Margin="0,10,0,0" 
           Grid.Row="3"/>

            <HyperlinkButton Content="View on GitHub" 
                             HorizontalAlignment="Right" 
                             VerticalAlignment="Center" 
                             Click="GitHubButton_Click"/>
        </Grid>
    </Grid>
</Window>